// ============================================================
// Shadow.frag.slang — 阴影贴图片元着色器
//
// 空着色器：仅写入深度，不需要颜色输出。
// ============================================================

struct FSInput {
};

float4 fragmentMain(FSInput input) : SV_Target0 {
    // 深度由固定管线写入，片元着色器无需输出
    return float4(0, 0, 0, 0);
}
